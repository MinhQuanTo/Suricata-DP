# Detekce normálního RDP připojení přes TCP port 3389
alert tcp any any -> any 3389 (msg:"[DP-QUAN] RDP Connection Attempt Detected (TCP)"; sid:2000001; rev:1;)

# Úplně blokovat RDP připojení přes TCP port 3389
drop tcp any any -> any 3389 (msg:"[DP-QUAN] RDP Connection Blocked (TCP)"; sid:2000004; rev:1;)
